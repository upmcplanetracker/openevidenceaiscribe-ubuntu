# ===== CLINIC AUDIO ROUTER CONFIG =====
#
# HOW TO CHOOSE NAMES:
# All values are matched case‑insensitively.
# Run ./discover-audio.sh to see your actual node names/descriptions.
#

# ------------------------------------------------------------
# HEADSET_NAME
# Used to find both your microphone (source) and headphones (sink).
# Use a unique manufacturer/model substring, e.g. "Jabra", "Logitech".
HEADSET_NAME="Jabra"

# ------------------------------------------------------------
# ZOOM_NAME
# Used to find Zoom's audio OUTPUT sink.
# From discover-audio.sh, look for a sink with description like "ZOOM VoiceEngine".
ZOOM_NAME="ZOOM VoiceEngine"

# ------------------------------------------------------------
# CHROME_NAME
# Used as a fallback to find Chrome's microphone input.
# Usually "Google Chrome" works.
CHROME_NAME="Google Chrome"

# ------------------------------------------------------------
# CHROME_INPUT_NAME
# Optional: exact PipeWire node name for Chrome's capture.
# If set, the script uses this directly (no searching).
# If empty, the script falls back to searching by CHROME_NAME.
# To get this value, run ./discover-audio.sh and look for "Chrome input:input_MONO"
CHROME_INPUT_NAME="Chrome input:input_MONO"

# ------------------------------------------------------------
# SCRIBE_SINK
# Name of the virtual (null) sink that mixes mic + Zoom.
# Do not change unless you know what you're doing.
SCRIBE_SINK="Scribe_Mixer"
